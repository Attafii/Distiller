# NewsAPI — https://newsapi.org/
# Get your free API key at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here
NEWSAPI_BASE_URL=https://newsapi.org/v2
NEWS_COUNTRY=us

# NVIDIA Build — https://build.nvidia.com/
# Get your API key from the NVIDIA Build dashboard
NVIDIA_BUILD_API_KEY=your_nvidia_build_key_here
NVIDIA_BUILD_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_BUILD_MODEL_FAST=nvidia/llama-3.1-nemotron-nano-8b-v1
NVIDIA_BUILD_MODEL_BALANCED=nvidia/llama-3.3-nemotron-super-49b-v1
NVIDIA_BUILD_MODEL_DEEP=nvidia/llama-3.1-nemotron-ultra-253b-v1
NVIDIA_BUILD_MODEL_CHAT=nvidia/llama-3.3-nemotron-super-49b-v1
NVIDIA_BUILD_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DISTILL_BATCH_SIZE=3

# Database — Neon PostgreSQL
# Get your connection string from https://neon.tech
# IMPORTANT: Rotate your password if exposed in chat
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Auth — https://better-auth.com/
# Generate these with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_here

# Stripe — https://stripe.com/
# Get your keys from the Stripe dashboard
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# OAuth (optional — for social login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Email (optional — for magic links and transactional emails)
EMAIL_FROM=noreply@distiller.attafii.app